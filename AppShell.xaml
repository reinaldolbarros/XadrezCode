<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ChessMAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ChessMAUI.Views"
    Title="Xadrez"
    Shell.BackgroundColor="#0F3460"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.DisabledColor="#AAAACC"
    Shell.TabBarBackgroundColor="#0F3460"
    Shell.TabBarForegroundColor="White"
    Shell.TabBarTitleColor="White"
    Shell.TabBarUnselectedColor="#AAAACC">

    <ShellContent
        Title="Lobby"
        ContentTemplate="{DataTemplate views:LobbyPage}"
        Route="LobbyPage"
        Shell.NavBarIsVisible="False"/>

</Shell>
