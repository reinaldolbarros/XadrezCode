<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChessMAUI.Views.ExtractPage"
             Title="Extrato"
             BackgroundColor="#1A1A2E">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ══ Cabeçalho: saldo e resumo ══ -->
        <Frame Grid.Row="0" BackgroundColor="#16213E" BorderColor="#0F3460"
               CornerRadius="0" Padding="16,14" HasShadow="False">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="SALDO ATUAL" TextColor="#AAAACC" FontSize="10"/>
                    <Label x:Name="BalanceLabel" Text="$ 0"
                           TextColor="#4CAF50" FontSize="24" FontAttributes="Bold"/>
                </VerticalStackLayout>
                <Frame Grid.Column="1" BackgroundColor="#0D2A0D" BorderColor="#4CAF50"
                       CornerRadius="10" Padding="12,8" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="1">
                        <Label Text="ENTRADAS"   TextColor="#4CAF50" FontSize="9" HorizontalTextAlignment="Center"/>
                        <Label x:Name="TotalInLabel" Text="$ 0"
                               TextColor="#4CAF50" FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="2" BackgroundColor="#2A0D0D" BorderColor="#FF5252"
                       CornerRadius="10" Padding="12,8" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="1">
                        <Label Text="SAÍDAS"     TextColor="#FF5252" FontSize="9" HorizontalTextAlignment="Center"/>
                        <Label x:Name="TotalOutLabel" Text="$ 0"
                               TextColor="#FF5252" FontSize="14" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Frame>

        <!-- ══ Filtros ══ -->
        <Frame Grid.Row="1" BackgroundColor="#16213E" BorderColor="Transparent"
               CornerRadius="0" Padding="12,8" HasShadow="False">
            <FlexLayout x:Name="FilterBar" Direction="Row" Wrap="Wrap"
                        JustifyContent="Start" AlignItems="Center"/>
        </Frame>

        <!-- ══ Lista de transações ══ -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="TransactionList" Padding="0" Spacing="0"/>
        </ScrollView>

    </Grid>
</ContentPage>
