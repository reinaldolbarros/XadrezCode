<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChessMAUI.Views.PointsExtractPage"
             Title="Extrato de Pontos"
             BackgroundColor="#1A1A2E">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Resumo -->
        <Frame Grid.Row="0" BackgroundColor="#16213E" BorderColor="Transparent"
               CornerRadius="0" Padding="16,12" HasShadow="False">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="PONTOS TOTAIS" TextColor="#AAAACC" FontSize="10"/>
                    <Label x:Name="TotalLabel" Text="0 pts"
                           TextColor="#FFD700" FontSize="20" FontAttributes="Bold"/>
                </VerticalStackLayout>
                <Frame Grid.Column="1" BackgroundColor="#1A1400" BorderColor="#FFD700"
                       CornerRadius="10" Padding="12,8" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="1">
                        <Label Text="SEMANA"  TextColor="#FFD700" FontSize="9" HorizontalTextAlignment="Center"/>
                        <Label x:Name="WeekLabel" Text="0 pts"
                               TextColor="#FFD700" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="2" BackgroundColor="#0D1A2A" BorderColor="#4CAF50"
                       CornerRadius="10" Padding="12,8" HasShadow="False">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="1">
                        <Label Text="TORNEIOS" TextColor="#4CAF50" FontSize="9" HorizontalTextAlignment="Center"/>
                        <Label x:Name="TourneysLabel" Text="0"
                               TextColor="#4CAF50" FontSize="13" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </Frame>

        <!-- Últimos 30 dias -->
        <Label Grid.Row="1" Text="Últimos 30 dias"
               TextColor="#444466" FontSize="10" FontAttributes="Bold"
               Padding="16,6" BackgroundColor="#0A0F1E"/>

        <!-- Lista -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="ExtractList" BackgroundColor="#0E1322" Spacing="0"/>
        </ScrollView>

    </Grid>
</ContentPage>
