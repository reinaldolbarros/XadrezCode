<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChessMAUI.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0D1421">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Spacing="0"
                             HorizontalOptions="Center"
                             MaximumWidthRequest="420"
                             MinimumHeightRequest="600">

            <!-- ══ Hero ══ -->
            <VerticalStackLayout Padding="32,60,32,40" Spacing="0" BackgroundColor="#0D1421">
                <Label Text="♟" FontSize="88"
                       HorizontalTextAlignment="Center"
                       TextColor="#F0D9B5"/>
                <Label Text="Xadrez"
                       FontSize="36" FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,6"/>
                <Label Text="Jogue. Evolua. Conquiste."
                       FontSize="14" TextColor="#4A5A7A"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- ══ Formulário ══ -->
            <VerticalStackLayout Padding="24,0" Spacing="10"
                                 BackgroundColor="#0D1421">

                <Border BackgroundColor="#111D32" Stroke="#1C2D4A"
                        StrokeThickness="1" StrokeShape="RoundRectangle 14"
                        Padding="18,6">
                    <Entry x:Name="EmailEntry"
                           Placeholder="E-mail"
                           PlaceholderColor="#354560" TextColor="White"
                           Keyboard="Email" ReturnType="Next"
                           BackgroundColor="Transparent" FontSize="16"/>
                </Border>

                <Border BackgroundColor="#111D32" Stroke="#1C2D4A"
                        StrokeThickness="1" StrokeShape="RoundRectangle 14"
                        Padding="18,6">
                    <Entry x:Name="PasswordEntry"
                           Placeholder="Senha  (mín. 6 caracteres)"
                           PlaceholderColor="#354560" TextColor="White"
                           IsPassword="True" ReturnType="Done"
                           Completed="OnPasswordCompleted"
                           BackgroundColor="Transparent" FontSize="16"/>
                </Border>

                <Label x:Name="ErrorLabel"
                       TextColor="#F87171" FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="False" Margin="0,2,0,0"/>

            </VerticalStackLayout>

            <!-- ══ Ações ══ -->
            <VerticalStackLayout Padding="24,20,24,40" Spacing="12"
                                 BackgroundColor="#0D1421">

                <!-- Entrar / Criar conta -->
                <Button Text="Entrar / Criar conta"
                        x:Name="LoginBtn"
                        Clicked="OnLoginClicked"
                        BackgroundColor="#1D4ED8"
                        TextColor="White"
                        FontAttributes="Bold" FontSize="16"
                        CornerRadius="14" HeightRequest="56"/>

                <!-- Divisor -->
                <Grid ColumnDefinitions="*,Auto,*" Margin="0,4">
                    <BoxView BackgroundColor="#1C2D4A" HeightRequest="1"
                             VerticalOptions="Center"/>
                    <Label Grid.Column="1" Text="  ou  "
                           TextColor="#2A3D5E" FontSize="13"/>
                    <BoxView Grid.Column="2" BackgroundColor="#1C2D4A"
                             HeightRequest="1" VerticalOptions="Center"/>
                </Grid>

                <!-- Entrar como visitante -->
                <Button Text="Entrar como visitante"
                        Clicked="OnAnonymousClicked"
                        BackgroundColor="#111D32"
                        TextColor="#7A90B4"
                        BorderColor="#1C2D4A" BorderWidth="1.5"
                        FontSize="16" CornerRadius="14" HeightRequest="56"/>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
