<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChessMAUI.Views.TournamentHistoryPage"
             Title="Histórico"
             BackgroundColor="#1A1A2E">

    <Grid RowDefinitions="Auto,*">

        <!-- Cabeçalho de estatísticas gerais -->
        <Frame Grid.Row="0" BackgroundColor="#16213E" BorderColor="Transparent"
               CornerRadius="0" Padding="16,12" HasShadow="False">
            <Grid ColumnDefinitions="*,*,*,*">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label x:Name="TotalLabel"  Text="0"   TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <Label Text="Jogados"        TextColor="#AAAACC" FontSize="11" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label x:Name="WonLabel"   Text="0"    TextColor="#FFD700" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <Label Text="Vitórias"      TextColor="#AAAACC" FontSize="11" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                    <Label x:Name="ProfitLabel" Text="+$ 0" TextColor="#4CAF50" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <Label Text="Lucro"          TextColor="#AAAACC" FontSize="11" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center">
                    <Label x:Name="RatingLabel"  Text="1200" TextColor="#AAAACC" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    <Label Text="Rating"          TextColor="#AAAACC" FontSize="11" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <!-- Lista de histórico -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="HistoryList" Padding="12,8" Spacing="8"/>
        </ScrollView>
    </Grid>
</ContentPage>
