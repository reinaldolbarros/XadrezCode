<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChessMAUI.Views.LobbyPage"
             Title="Xadrez Online"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="0">

            <!-- ══ Perfil ══ -->
            <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                   CornerRadius="14" Padding="16,12" Margin="0,0,0,6">
                <VerticalStackLayout Spacing="4">
                    <Grid ColumnDefinitions="Auto,*,Auto">

                        <!-- Avatar (toque para trocar) -->
                        <Frame Grid.Column="0" BackgroundColor="#0F3460" CornerRadius="28"
                               WidthRequest="56" HeightRequest="56" Padding="0" HasShadow="False"
                               Margin="0,0,12,0">
                            <Label x:Name="AvatarLabel" Text="♟" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                            </Frame.GestureRecognizers>
                        </Frame>

                        <!-- Nome + rank -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label x:Name="NameLabel"   Text="Jogador"
                                   TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            <HorizontalStackLayout Spacing="6">
                                <Label x:Name="TierLabel"  Text="♟" FontSize="14" VerticalOptions="Center"/>
                                <Label x:Name="TierName"   Text="Pião"
                                       TextColor="#FFD700" FontSize="12" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label x:Name="RatingLabel" Text="Rating: 1200 · 0 pts"
                                   TextColor="#AAAACC" FontSize="11"/>
                        </VerticalStackLayout>

                        <!-- Saldo + botão extrato -->
                        <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                            <Frame BackgroundColor="#0F3460" CornerRadius="10"
                                   Padding="12,8" HasShadow="False">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="SALDO" TextColor="#AAAACC" FontSize="9" HorizontalTextAlignment="Center"/>
                                    <Label x:Name="BalanceLabel" Text="$ 1.000"
                                           TextColor="#4CAF50" FontSize="18" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAdminActivate"/>
                                </Frame.GestureRecognizers>
                            </Frame>
                            <Button Text="📋 Extrato"
                                    Clicked="OnExtractClicked"
                                    BackgroundColor="#1C2A4A"
                                    TextColor="#AAAACC"
                                    FontSize="10"
                                    CornerRadius="8"
                                    Padding="0,4"
                                    HeightRequest="26"/>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Sair da conta -->
                    <Button x:Name="LogoutBtn" Text="Sair da conta"
                            Clicked="OnLogoutClicked"
                            BackgroundColor="Transparent" TextColor="#555577"
                            FontSize="10" HeightRequest="22" Padding="0"
                            HorizontalOptions="End"/>
                </VerticalStackLayout>
            </Frame>

            <!-- ══ Bônus Diário ══ -->
            <Frame x:Name="BonusFrame" BackgroundColor="#16213E" BorderColor="#FFD700"
                   CornerRadius="12" Padding="14,10" Margin="0,0,0,8">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                        <Label x:Name="BonusTitle" Text="🎁  Bônus Diário"
                               TextColor="#FFD700" FontSize="14" FontAttributes="Bold"/>
                        <Label x:Name="BonusStreakLabel" Text="Sequência: 1 dia"
                               TextColor="#AAAACC" FontSize="11"/>
                    </VerticalStackLayout>
                    <Button x:Name="BonusBtn" Text="RESGATAR"
                            Grid.Column="1"
                            Clicked="OnBonusClicked"
                            BackgroundColor="#FFD700" TextColor="#1A1A2E"
                            FontAttributes="Bold" FontSize="12"
                            CornerRadius="8" HeightRequest="36" WidthRequest="90"/>
                </Grid>
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Frame.GestureRecognizers>
            </Frame>

            <!-- ══ Missões Diárias ══ -->
            <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                   CornerRadius="12" Padding="14,10" Margin="0,0,0,12">
                <VerticalStackLayout Spacing="6">
                    <Label Text="📋  Missões de Hoje" TextColor="White"
                           FontSize="13" FontAttributes="Bold" Margin="0,0,0,4"/>
                    <VerticalStackLayout x:Name="MissionContainer" Spacing="6"/>
                </VerticalStackLayout>
            </Frame>

            <!-- ══ Estatísticas ══ -->
            <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                   CornerRadius="14" Padding="14,10" Margin="0,0,0,10">
                <Grid ColumnDefinitions="*,*,*">
                    <VerticalStackLayout HorizontalOptions="Center">
                        <Label x:Name="WinsLabel"     Text="0" TextColor="#4CAF50" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        <Label Text="Vitórias"          TextColor="#AAAACC" FontSize="11" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                        <Label x:Name="LossesLabel"   Text="0" TextColor="#FF5252" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        <Label Text="Derrotas"          TextColor="#AAAACC" FontSize="11" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                        <Label x:Name="TournWinsLabel" Text="0" TextColor="#FFD700" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        <Label Text="Torneios Vencidos" TextColor="#AAAACC" FontSize="11" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- ══ Botões principais ══ -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,0,0,10">
                <Button Text="🏆  Torneios"
                        Clicked="OnTournamentsClicked"
                        BackgroundColor="#0F3460"
                        TextColor="White" FontAttributes="Bold" FontSize="14"
                        CornerRadius="12" HeightRequest="52"/>

                <Button Grid.Column="1"
                        Text="🏅  Ranking"
                        Clicked="OnRankingClicked"
                        BackgroundColor="#4A1060"
                        TextColor="White" FontAttributes="Bold" FontSize="14"
                        CornerRadius="12" HeightRequest="52"/>
            </Grid>

            <Button Text="♟  Jogo Rápido vs IA"
                    x:Name="QuickPlayBtn"
                    Clicked="OnQuickPlayClicked"
                    BackgroundColor="#769656"
                    TextColor="White" FontAttributes="Bold" FontSize="15"
                    CornerRadius="12" HeightRequest="52" Margin="0,0,0,12"/>

            <!-- ══ Mini Ranking ══ -->
            <Frame BackgroundColor="#16213E" BorderColor="#0F3460"
                   CornerRadius="14" Padding="14,12" Margin="0,0,0,8">
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <Label Text="🏅  Top Jogadores" TextColor="White"
                               FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Label Text="ver todos →" Grid.Column="1"
                               TextColor="#7B68EE" FontSize="11" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRankingClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    <VerticalStackLayout x:Name="MiniRankContainer" Spacing="4"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
